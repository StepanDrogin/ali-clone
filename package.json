    "@types/node": "^22.20.0",
    "nuxt": "^3.21.8",
    "nuxt-icon": "^0.3.3",
    "nuxt-lodash": "^2.5.3",
    "pinia": "^2.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vue-stripe-js": "^1.0.4"
  },
  "dependencies": {
    "@netlify/functions": "^5.3.0",
