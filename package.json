    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "dev": "nuxt dev",
    "deploy:preview": "npx netlify deploy --build",
    "deploy:prod": "npx netlify deploy --build --prod",
